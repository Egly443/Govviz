  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/router-plugin": "^1.95.1",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "marked": "^18.0.5",
    "tailwindcss": "^4.0.0",
